generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes", "views"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model identity_type {
  id          Int        @id(map: "identity_type_pk")
  abr         String     @db.VarChar(5)
  name        String     @db.VarChar(200)
  dian_code   String?    @db.VarChar(500)
  description String?    @db.VarChar(1000)
  clientes    clientes[]
  users       users[]

  @@schema("public")
}

model users {
  id               Int           @id @default(autoincrement())
  email            String        @unique @db.VarChar(150)
  username         String        @unique(map: "users_name_unq") @db.VarChar(500)
  passwd           String        @unique @db.VarChar(2000)
  id_identity_type Int
  identity_number  String        @db.VarChar(50)
  active           Boolean       @default(true)
  firts_names      String        @db.VarChar(100)
  last_names       String        @db.VarChar(100)
  phone_number     String?       @db.VarChar(30)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  identity_type    identity_type @relation(fields: [id_identity_type], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_identity_type_fk")

  @@unique([id_identity_type, identity_number], map: "users_identity_number_type_unique")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model clientes {
  id                     Int           @id(map: "clientes_pk") @default(autoincrement())
  id_tipo_identificacion Int
  identificacion         Int           @unique(map: "clientes_unique")
  nombres                String        @db.VarChar(80)
  apellidos              String        @db.VarChar(80)
  fecha_nacimiento       DateTime      @db.Date
  numero_celular         String        @db.VarChar(20)
  email                  String        @unique(map: "clientes_unique_1") @db.VarChar(1000)
  estado                 Boolean       @default(true)
  identity_type          identity_type @relation(fields: [id_tipo_identificacion], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "clientes_identity_type_fk")
  servicios              servicios[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model servicios {
  id                 Int            @id(map: "servicios_pk2") @default(autoincrement())
  id_cliente         Int
  id_tipo_servicio   Int
  fecha_inicio       DateTime       @db.Date
  ultima_facturacion DateTime       @db.Date
  ultimo_pago        Int            @default(0)
  estado             Boolean        @default(true)
  clientes           clientes       @relation(fields: [id_cliente], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "servicios_clientes_fk")
  tipo_servicios     tipo_servicios @relation(fields: [id_tipo_servicio], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "servicios_tipo_servicios_fk")

  @@unique([id_cliente, id_tipo_servicio, estado], map: "servicios_unique")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tipo_servicios {
  id        Int         @id(map: "servicios_pk")
  nombre    String      @unique(map: "tipo_servicios_unique") @db.VarChar
  servicios servicios[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ref_files {
  id           Int    @id(map: "ref_files_pk") @default(autoincrement())
  nom_file     String @db.VarChar
  path_storage String @db.VarChar

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agrupacion_ifc {
  id              Int            @id @default(autoincrement())
  modelo_id       Int?
  tipo_agrupacion String         @db.VarChar(100)
  nombre          String         @db.VarChar(255)
  global_id_ifc   String?        @unique @db.VarChar(50)
  modelo_ifc      modelo_ifc?    @relation(fields: [modelo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  elemento_ifc    elemento_ifc[]

  @@index([modelo_id])
  @@schema("public")
}

model cantidad_ifc {
  id              Int           @id @default(autoincrement())
  elemento_id     Int?
  nombre_cantidad String        @db.VarChar(150)
  valor           Decimal       @db.Decimal(12, 4)
  unidad          String?       @db.VarChar(50)
  elemento_ifc    elemento_ifc? @relation(fields: [elemento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([nombre_cantidad], map: "idx_cantidad_nombre")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model elemento_ifc {
  id               Int             @id @default(autoincrement())
  modelo_id        Int?
  agrupacion_id    Int?
  global_id        String          @unique @db.VarChar(50)
  tipo_entidad_ifc String          @db.VarChar(100)
  nombre           String?         @db.VarChar(255)
  etiqueta_id      String?         @db.VarChar(50)
  cantidad_ifc     cantidad_ifc[]
  agrupacion_ifc   agrupacion_ifc? @relation(fields: [agrupacion_id], references: [id], onUpdate: NoAction)
  modelo_ifc       modelo_ifc?     @relation(fields: [modelo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property_set     property_set[]

  @@index([global_id], map: "idx_elemento_global_id")
  @@index([modelo_id])
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model modelo_ifc {
  id                  Int              @id @default(autoincrement())
  nombre_archivo      String           @unique(map: "modelo_ifc_unique") @db.VarChar(255)
  esquema_ifc         String           @db.VarChar(50)
  fecha_procesado     DateTime?        @db.Date
  aplicacion_creadora String?          @db.VarChar(255)
  totales_elementos   Int?             @default(0)
  agrupacion_ifc      agrupacion_ifc[]
  elemento_ifc        elemento_ifc[]

  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model property_set {
  id                  Int                   @id @default(autoincrement())
  elemento_id         Int?
  nombre_pset         String                @db.VarChar(150)
  elemento_ifc        elemento_ifc?         @relation(fields: [elemento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  propiedad_parametro propiedad_parametro[]

  @@index([elemento_id])
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model propiedad_parametro {
  id               Int           @id @default(autoincrement())
  pset_id          Int?
  nombre_propiedad String        @db.VarChar(150)
  valor            String?       @db.VarChar(255)
  tipo_valor       String?       @db.VarChar(50)
  property_set     property_set? @relation(fields: [pset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([nombre_propiedad], map: "idx_propiedad_nombre")
  @@schema("public")
}

view pg_stat_statements_info {
  dealloc     BigInt?
  stats_reset DateTime? @db.Timestamptz(6)

  @@schema("public")
}

view pg_stat_statements {
  userid                 Int?      @db.Oid
  dbid                   Int?      @db.Oid
  toplevel               Boolean?
  queryid                BigInt?
  query                  String?
  plans                  BigInt?
  total_plan_time        Float?
  min_plan_time          Float?
  max_plan_time          Float?
  mean_plan_time         Float?
  stddev_plan_time       Float?
  calls                  BigInt?
  total_exec_time        Float?
  min_exec_time          Float?
  max_exec_time          Float?
  mean_exec_time         Float?
  stddev_exec_time       Float?
  rows                   BigInt?
  shared_blks_hit        BigInt?
  shared_blks_read       BigInt?
  shared_blks_dirtied    BigInt?
  shared_blks_written    BigInt?
  local_blks_hit         BigInt?
  local_blks_read        BigInt?
  local_blks_dirtied     BigInt?
  local_blks_written     BigInt?
  temp_blks_read         BigInt?
  temp_blks_written      BigInt?
  shared_blk_read_time   Float?
  shared_blk_write_time  Float?
  local_blk_read_time    Float?
  local_blk_write_time   Float?
  temp_blk_read_time     Float?
  temp_blk_write_time    Float?
  wal_records            BigInt?
  wal_fpi                BigInt?
  wal_bytes              Decimal?  @db.Decimal
  jit_functions          BigInt?
  jit_generation_time    Float?
  jit_inlining_count     BigInt?
  jit_inlining_time      Float?
  jit_optimization_count BigInt?
  jit_optimization_time  Float?
  jit_emission_count     BigInt?
  jit_emission_time      Float?
  jit_deform_count       BigInt?
  jit_deform_time        Float?
  stats_since            DateTime? @db.Timestamptz(6)
  minmax_stats_since     DateTime? @db.Timestamptz(6)

  @@schema("public")
}
