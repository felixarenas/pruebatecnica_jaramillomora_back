DATABASE_URL="postgres://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_DATABASE?schema=public"

# Redis: localhost para npm run start:dev; en Docker Compose la API usa REDIS_HOST=redis-cache
