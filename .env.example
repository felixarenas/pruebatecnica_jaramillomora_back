SERVER_PORT=3050
HOST=localhost
DB_HOST=localhost
DB_DATABASE=namedb
DB_USER=userdb
DB_PASSWORD=passdb
DB_PORT=5432
POSTGRES_DATA_PATH="/media/datos/datosdocker/dbpostgres/jm/data"
DURATION_TOKEN=15d
SECRECT_KEY=prueba-jwt-secret-key-development-only-min-256-bits!!

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

DATABASE_URL="postgres://userdb:passdb@localhost:5453/namedb?schema=public"

# Redis (npm run start:dev en el host → localhost; Docker Compose sobrescribe REDIS_HOST en el contenedor API)
REDIS_HOST=localhost
REDIS_HOST_DOCKER=redis-cache-jm
REDIS_PORT=6390
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
REDIS_MAXMEMORY=256mb
REDIS_MEMORY_LIMIT=512M
REDIS_MEMORY_RESERVATION=256M
REDIS_DATA_PATH=./redis/data
REDIS_LOGS_PATH=./redis/logs
REDIS_COMMANDER_PORT=8091
REDIS_TTL=86400
REDIS_MAX_ITEMS=1000
# Límite del body HTTP para JSON con archivos en base64 (process-ifc, etc.)
BODY_LIMIT=100mb
# Orígenes CORS (coma-separados). Frontend Angular + fetch a /storage
CORS_ORIGINS=http://localhost:4200